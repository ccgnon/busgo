{
  "name": "busgo",
  "version": "1.0.0",
  "description": "busGO — script de démarrage unifié",
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix frontend && npm install --prefix agent",
    "dev":         "concurrently --kill-others-on-fail --prefix-colors \"bgBlue.bold,bgGreen.bold,bgMagenta.bold\" \"npm:dev:backend\" \"npm:dev:frontend\" \"npm:dev:agent\"",
    "dev:backend":  "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:agent":    "npm run dev --prefix agent",
    "dev:no-agent": "concurrently --kill-others-on-fail --prefix-colors \"bgBlue.bold,bgGreen.bold\" \"npm:dev:backend\" \"npm:dev:frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
